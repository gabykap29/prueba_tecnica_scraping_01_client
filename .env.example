# Rappi Analytics Frontend
# Copy this file to .env.local in the frontend root when you need overrides.

# -----------------------------------------------------------------------------
# Backend proxy used by Next.js rewrites
# -----------------------------------------------------------------------------

# Server-side URL used by next.config.js to proxy /api/* requests.
# Recommended local value while the FastAPI backend runs on port 8000.
BACKEND_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# Browser API base URL
# -----------------------------------------------------------------------------

# Leave empty for the recommended setup: the browser calls /api/v1/... and Next
# proxies it to BACKEND_URL. This avoids CORS and host mismatch issues.
NEXT_PUBLIC_API_URL=

# Use this only if you intentionally want the browser to call FastAPI directly.
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
